{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["dom", "dom.iterable", "esnext"],
        "jsx": "react-jsx",
        "jsxImportSource": "@infinite-canvas/plugin-sdk",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "types": []
    },
    "include": ["src"]
}
