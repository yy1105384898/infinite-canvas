{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["dom", "dom.iterable", "esnext"],
        "jsx": "react-jsx",
        "jsxImportSource": ".",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "allowJs": true,
        "checkJs": false
    },
    "include": ["src", "build.mjs"]
}
